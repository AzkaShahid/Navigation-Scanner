    <!-- Transparent overlay for drawing routes -->


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_80"
        >
        <Button
            android:id="@+id/agricultureDdepartment"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:visibility="invisible"
            android:layout_marginTop="@dimen/margin_80"
            android:layout_marginLeft="240dp"

            />

        <Button
            android:id="@+id/engineeringDepartment"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:visibility="invisible"
            android:layout_marginTop="@dimen/margin_80"
            android:layout_marginLeft="-150dp"
            android:layout_alignLeft="@+id/agricultureDdepartment" />
        <Button
            android:id="@+id/lawDepartment"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:visibility="invisible"
            android:layout_marginTop="250dp"
            android:layout_marginLeft="220dp"
            />
        <Button
            android:id="@+id/libraryDepartment"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:visibility="invisible"
            android:layout_marginTop="250dp"
            android:layout_marginLeft="80dp"
            />
        <Button
            android:id="@+id/nursingDepartment"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:visibility="invisible"
            android:layout_marginTop="370dp"
            android:layout_marginLeft="200dp"
            />

        <Button
            android:id="@+id/economicsDepartment"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:visibility="invisible"
            android:layout_marginLeft="300dp"
            android:layout_marginTop="430dp"
             />
        <Button
            android:id="@+id/hospitalDepartment"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:visibility="invisible"
            android:layout_marginTop="460dp"
            android:layout_marginLeft="80dp"
            />
        <Button
            android:id="@+id/cinemaDepartment"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:visibility="invisible"
            android:layout_marginTop="575dp"
            android:layout_marginLeft="200dp"
            />
        <Button
            android:id="@+id/administrativeDepartment"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:visibility="invisible"
            android:layout_marginTop="600dp"
            android:layout_marginLeft="@dimen/margin_80"
            />

    </RelativeLayout>


    <com.app.ui.sidenavigation.home.RouteOverlay
        android:id="@+id/routeOverlay"
        android:layout_width="match_parent"

        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_alignParentLeft="true"/>


    <!-- Search inputs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:orientation="horizontal"

        >

        <EditText
            android:id="@+id/fromInput"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:textSize="@dimen/font_12"
            android:hint="From Department"
            android:layout_marginEnd="@dimen/margin_10"
            android:background="@drawable/ic_text_bg"
            android:padding="@dimen/margin_8"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/toInput"
            android:layout_width="0dp"
            android:textSize="@dimen/font_12"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_10"
            android:hint="To Department"
            android:background="@drawable/ic_text_bg"
            android:padding="@dimen/margin_8"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnRoute"
            android:layout_width="wrap_content"
            android:text="Route"
            android:textColor="@color/white"
            android:textSize="@dimen/font_14"
            android:backgroundTint="@color/black"
            android:layout_height="wrap_content" />
    </LinearLayout>
</RelativeLayout>
