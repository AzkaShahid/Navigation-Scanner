<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/ic_bg_cover"
    >
    <TextView
        android:id="@+id/tvWelcom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WELCOME!"
        android:textStyle="bold"
        android:fontFamily="@font/catilde_semibold"
        android:textColor="@color/white"
        android:gravity="start"
        android:textSize="@dimen/font_30"
        android:layout_marginHorizontal="@dimen/margin_20"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/margin_100"
        android:layout_marginBottom="@dimen/margin_10"
        />



    <TextView
        android:id="@+id/tvHeading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="EUL Helper"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="start"
        android:fontFamily="@font/catilde_semibold"
        android:textSize="@dimen/font_24"
        android:layout_marginTop="@dimen/margin_50"
        android:layout_marginHorizontal="@dimen/margin_20"
app:layout_constraintTop_toBottomOf="@+id/tvWelcom"
        android:layout_marginBottom="@dimen/margin_10"
        />


    <TextView
        android:id="@+id/tvContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_10"
        android:text="Chat to find directions, office info, and student services—all in one place."
        android:textSize="@dimen/font_14"
        android:layout_marginHorizontal="@dimen/margin_20"
        android:textColor="@color/white"
        android:fontFamily=""
        app:layout_constraintTop_toBottomOf="@+id/tvHeading"
        android:layout_marginBottom="120dp"
        android:textAlignment="textStart"

        />


    <androidx.cardview.widget.CardView
        android:id="@+id/findLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/light_green"
        app:cardCornerRadius="@dimen/margin_10"
        android:layout_gravity="bottom"
        android:layout_marginTop="@dimen/font_30"
      app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="@dimen/margin_25"
        android:layout_marginBottom="200dp"

>
        <TextView
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get Started"
            android:textColor="@color/white"
            android:paddingHorizontal="@dimen/margin_10"
            android:paddingVertical="@dimen/margin_8"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="@dimen/font_16"
            android:textAlignment="center"/>


    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>


